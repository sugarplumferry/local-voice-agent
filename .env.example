# ── Service URLs ──────────────────────────────────────────────────────────────
# Use Docker service names when running inside Docker Compose
OLLAMA_BASE_URL=http://ollama:11434
SPEACHES_BASE_URL=http://speaches:8000
REDIS_URL=redis://redis:6379

# ── Ollama model ───────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.1:8b

# ── Whisper (STT) ──────────────────────────────────────────────────────────────
WHISPER_MODEL=small          # small = fast CPU; large-v3-turbo = best quality (needs GPU)
WHISPER_LANGUAGE=en          # skip auto-detection for lower latency

# ── Speaches (TTS) ─────────────────────────────────────────────────────────────
TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX-fp16
TTS_VOICE=af_heart

# ── LangSmith tracing (optional) ───────────────────────────────────────────────
# Get a free key at https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=local-voice-agent
LANGCHAIN_TRACING_V2=true
