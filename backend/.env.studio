# LangGraph Studio runs inside the backend container — use Docker service names
OLLAMA_BASE_URL=http://ollama:11434
SPEACHES_BASE_URL=http://speaches:8000
REDIS_URL=redis://redis:6379

OLLAMA_MODEL=llama3.1:8b

TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX-fp16
TTS_VOICE=af_heart

# Whisper is not called inside the graph, these are just to satisfy Settings()
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=local-voice-agent
LANGCHAIN_TRACING_V2=true
